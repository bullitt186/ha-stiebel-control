# secrets.yaml — copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored and must NEVER be committed.

# Wi-Fi credentials
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# MQTT broker (IP address or hostname)
mqtt_broker: 192.168.1.10
mqtt_username: "your_mqtt_user"
mqtt_password: "your_mqtt_password"

# ESPHome API encryption key (32-byte base64 — generate with:  python3 -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"  )
# Must match the key stored in Home Assistant's ESPHome integration config entry.
api_encryption_key: "your-32-byte-base64-key-here=="

# ESPHome OTA password
ota_password: "change_me_to_a_random_string"
